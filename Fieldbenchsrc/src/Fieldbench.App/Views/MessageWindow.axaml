<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Fieldbench.App.Views.MessageWindow"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource FbPanel}"
        FontFamily="{StaticResource FbSans}"
        FontSize="12">

    <StackPanel Margin="20,18">
        <TextBlock Name="TitleText" FontSize="15" FontWeight="Medium" Margin="0,0,0,10" />
        <TextBlock Name="MessageText" FontSize="12" Foreground="{DynamicResource FbGraphite}" TextWrapping="Wrap"
                   LineHeight="18" Margin="0,0,0,18" />
        <Button Classes="primary" Content="{DynamicResource L.OK}" HorizontalAlignment="Right" Click="OnOk" />
    </StackPanel>
</Window>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Fieldbench.App.ViewModels"
             xmlns:conv="using:Fieldbench.App.Converters"
             x:Class="Fieldbench.App.Views.SessionSideView"
             x:DataType="vm:SessionViewModel">

    <UserControl.Resources>
        <conv:FieldKindBrushConverter x:Key="FieldBrush" />
        <conv:FieldKindBrushConverter x:Key="FieldTint" Tint="True" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ── byte inspector ── -->
        <Border Grid.Row="0" BorderBrush="{DynamicResource FbCloud}" BorderThickness="0,0,0,1"
                Padding="16,13,16,14">
            <StackPanel DataContext="{Binding Inspector}" x:DataType="vm:InspectorViewModel">
                <DockPanel Margin="0,0,0,10">
                    <TextBlock Text="{DynamicResource L.ByteInspector}" Classes="micro" />
                    <TextBlock Text="{Binding FrameLabel}" Classes="mono" FontSize="10.5"
                               Foreground="{DynamicResource FbSilver}" DockPanel.Dock="Right"
                               HorizontalAlignment="Right" />
                </DockPanel>

                <TextBlock Text="{DynamicResource L.SelectFrame}" FontSize="11.5"
                           Foreground="{DynamicResource FbGhostText}" IsVisible="{Binding IsEmpty}"
                           Margin="0,6" />

                <!-- byte grid, 8 per row, field-colored -->
                <ItemsControl ItemsSource="{Binding Bytes}" IsVisible="{Binding HasFrame}" Margin="0,0,0,12">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="8" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ByteCellViewModel">
                            <Border Height="22" Margin="1" CornerRadius="3"
                                    Background="{Binding Kind, Converter={StaticResource FieldTint}}"
                                    ToolTip.Tip="{Binding Tooltip}">
                                <TextBlock Text="{Binding Hex}" Classes="mono" FontSize="11"
                                           Foreground="{Binding Kind, Converter={StaticResource FieldBrush}}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- parsed fields -->
                <ItemsControl ItemsSource="{Binding Fields}" IsVisible="{Binding HasFrame}" Margin="0,0,0,11">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:FieldRowViewModel">
                            <Border Height="25" BorderBrush="{DynamicResource FbRowLine}" BorderThickness="0,0,0,1">
                                <DockPanel VerticalAlignment="Center">
                                    <Rectangle Width="2" Height="12" RadiusX="1" RadiusY="1" DockPanel.Dock="Left"
                                               Fill="{Binding Kind, Converter={StaticResource FieldBrush}}" />
                                    <TextBlock Text="{Binding Name}" FontSize="11" Width="94" Margin="10,0,0,0"
                                               Foreground="{DynamicResource FbSilver}" DockPanel.Dock="Left"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Detail}" Classes="mono" FontSize="10.5"
                                               Foreground="{DynamicResource FbSilver}" DockPanel.Dock="Right"
                                               HorizontalAlignment="Right" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Value}" Classes="mono" FontSize="11.5"
                                               Foreground="{DynamicResource FbCarbon}" Margin="0,0,8,0"
                                               Classes.bad="{Binding IsBad}" VerticalAlignment="Center">
                                        <TextBlock.Styles>
                                            <Style Selector="TextBlock.bad">
                                                <Setter Property="Foreground" Value="{DynamicResource FbRed}" />
                                            </Style>
                                        </TextBlock.Styles>
                                    </TextBlock>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- raw-lens hints -->
                <TextBlock Text="{Binding AsciiPreview}" Classes="mono" FontSize="11" LetterSpacing="1.4"
                           Foreground="{DynamicResource FbGhostText}" IsVisible="{Binding ShowNoLensHint}"
                           Margin="0,0,0,8" TextTrimming="CharacterEllipsis" />
                <TextBlock Text="{DynamicResource L.NoLens}" FontSize="11" Foreground="{DynamicResource FbSilver}"
                           IsVisible="{Binding ShowNoLensHint}" Margin="0,0,0,10" />

                <!-- legend -->
                <Border BorderBrush="{DynamicResource FbCloud}" BorderThickness="0,1,0,0" Padding="0,10,0,0"
                        IsVisible="{Binding HasFrame}">
                    <StackPanel Orientation="Horizontal" Spacing="14">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Rectangle Width="2" Height="10" Fill="{DynamicResource FbFieldAddr}" />
                            <TextBlock Text="{DynamicResource L.Addr}" Classes="micro" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Rectangle Width="2" Height="10" Fill="{DynamicResource FbFieldFunc}" />
                            <TextBlock Text="{DynamicResource L.Func}" Classes="micro" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Rectangle Width="2" Height="10" Fill="{DynamicResource FbFieldLen}" />
                            <TextBlock Text="{DynamicResource L.Len}" Classes="micro" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Rectangle Width="2" Height="10" Fill="{DynamicResource FbFieldData}" />
                            <TextBlock Text="{DynamicResource L.Data}" Classes="micro" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Rectangle Width="2" Height="10" Fill="{DynamicResource FbRed}" />
                            <TextBlock Text="{DynamicResource L.Crc}" Classes="micro" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- ── AI explain ── -->
        <Grid Grid.Row="1" RowDefinitions="Auto,*,Auto" Margin="0">
            <DockPanel Grid.Row="0" Margin="16,13,16,10">
                <TextBlock Text="✦" FontSize="12" Foreground="{DynamicResource FbBlue}" Margin="0,0,8,0" />
                <TextBlock Text="{DynamicResource L.AiExplain}" Classes="micro" Foreground="{DynamicResource FbBlue}" />
                <TextBlock Text="{Binding Ai.FrameLabel}" Classes="mono" FontSize="10.5"
                           Foreground="{DynamicResource FbSilver}" DockPanel.Dock="Right"
                           HorizontalAlignment="Right" />
            </DockPanel>

            <!-- empty state -->
            <StackPanel Grid.Row="1" Margin="16,0" VerticalAlignment="Center" IsVisible="{Binding Ai.IsEmpty}">
                <TextBlock Text="{DynamicResource L.AiEmpty}" FontSize="12.5"
                           Foreground="{DynamicResource FbGraphite}" Margin="0,0,0,8" />
                <Button Padding="0" Background="Transparent" BorderThickness="0" HorizontalAlignment="Stretch"
                        Command="{Binding Ai.ExplainCommand}">
                    <Border Height="30" BorderBrush="{DynamicResource FbRowLine}" BorderThickness="0,0,0,1">
                        <DockPanel VerticalAlignment="Center">
                            <TextBlock Text="01" Classes="mono" FontSize="10" Foreground="{DynamicResource FbBlue}"
                                       Margin="0,0,10,0" />
                            <TextBlock Text="→" FontSize="10" Foreground="{DynamicResource FbSilver}"
                                       DockPanel.Dock="Right" HorizontalAlignment="Right" />
                            <TextBlock Text="{DynamicResource L.AiExplainSelection}" FontSize="11.5"
                                       Foreground="{DynamicResource FbGraphite}" />
                        </DockPanel>
                    </Border>
                </Button>
                <Button Padding="0" Background="Transparent" BorderThickness="0" HorizontalAlignment="Stretch"
                        Command="{Binding Ai.ExplainCommand}" IsVisible="{Binding IsMonitor}">
                    <Border Height="30">
                        <DockPanel VerticalAlignment="Center">
                            <TextBlock Text="02" Classes="mono" FontSize="10" Foreground="{DynamicResource FbBlue}"
                                       Margin="0,0,10,0" />
                            <TextBlock Text="→" FontSize="10" Foreground="{DynamicResource FbSilver}"
                                       DockPanel.Dock="Right" HorizontalAlignment="Right" />
                            <TextBlock Text="{DynamicResource L.AiIdentify}" FontSize="11.5"
                                       Foreground="{DynamicResource FbGraphite}" />
                        </DockPanel>
                    </Border>
                </Button>
            </StackPanel>

            <!-- streaming / result -->
            <ScrollViewer Grid.Row="1" Margin="16,0" IsVisible="{Binding Ai.HasContent}">
                <StackPanel Spacing="12">
                    <TextBlock Text="{Binding Ai.Verdict}" FontSize="12" LineHeight="19" TextWrapping="Wrap"
                               Foreground="{DynamicResource FbGraphite}" />

                    <ItemsControl ItemsSource="{Binding Ai.Causes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:AiCauseRow">
                                <Border Height="26" BorderBrush="{DynamicResource FbRowLine}" BorderThickness="0,0,0,1">
                                    <DockPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Rank}" Classes="mono" FontSize="10"
                                                   Foreground="{DynamicResource FbSilver}" Margin="0,0,10,0" />
                                        <TextBlock Text="{Binding Level}" Classes="micro" Width="52" TextAlignment="Right"
                                                   DockPanel.Dock="Right" VerticalAlignment="Center" />
                                        <Border DockPanel.Dock="Right" Width="56" Height="2" CornerRadius="1"
                                                Background="{DynamicResource FbCloud}" Margin="0,0,8,0"
                                                VerticalAlignment="Center">
                                            <Rectangle HorizontalAlignment="Left" Fill="{DynamicResource FbBlue}"
                                                       Width="{Binding Likelihood, Converter={x:Static vm:UiMath.Times56}}" />
                                        </Border>
                                        <TextBlock Text="{Binding Text}" FontSize="11.5"
                                                   Foreground="{DynamicResource FbCarbon}" TextTrimming="CharacterEllipsis" />
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ItemsControl ItemsSource="{Binding Ai.Checks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:AiCheckRow">
                                <Border Height="26" BorderBrush="{DynamicResource FbRowLine}" BorderThickness="0,0,0,1">
                                    <DockPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Number}" Classes="mono" FontSize="10"
                                                   Foreground="{DynamicResource FbBlue}" Margin="0,0,10,0" />
                                        <TextBlock Text="{Binding Action}" FontSize="10"
                                                   Foreground="{DynamicResource FbSilver}" DockPanel.Dock="Right"
                                                   HorizontalAlignment="Right" />
                                        <TextBlock Text="{Binding Text}" FontSize="11.5"
                                                   Foreground="{DynamicResource FbGraphite}" TextTrimming="CharacterEllipsis" />
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ItemsControl ItemsSource="{Binding Ai.FieldNotes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:FieldNoteViewModel">
                                <StackPanel Orientation="Horizontal" Spacing="8" Height="22">
                                    <TextBlock Text="{Binding Field}" FontSize="11" Width="94"
                                               Foreground="{DynamicResource FbSilver}" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Meaning}" Classes="mono" FontSize="11"
                                               Foreground="{DynamicResource FbGraphite}" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- ask box + footer -->
            <StackPanel Grid.Row="2">
                <TextBlock Text="{Binding Ai.NoticeText}" FontSize="11" Foreground="{DynamicResource FbAmber}"
                           TextWrapping="Wrap" Margin="16,8,16,0"
                           IsVisible="{Binding Ai.HasNotice}" />
                <TextBox Text="{Binding Ai.Question}" Watermark="{DynamicResource L.AiAsk}"
                         Margin="16,10,16,12" MinHeight="30" Height="30" FontSize="11.5"
                         Background="{DynamicResource FbAsh}" />
                <Border Height="32" BorderBrush="{DynamicResource FbCloud}" BorderThickness="0,1,0,0">
                    <DockPanel Margin="16,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="{DynamicResource L.AiTrial}" FontSize="11"
                                       Foreground="{DynamicResource FbSilver}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Ai.QuotaLabel}" Classes="mono" FontSize="11" FontWeight="Medium"
                                       Foreground="{DynamicResource FbBlue}" VerticalAlignment="Center" />
                            <TextBlock Text="{DynamicResource L.AiLeft}" FontSize="11"
                                       Foreground="{DynamicResource FbSilver}" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="{DynamicResource L.Subscribe}" FontSize="11" FontWeight="Medium"
                                   Foreground="{DynamicResource FbBlue}" DockPanel.Dock="Right"
                                   HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </DockPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>

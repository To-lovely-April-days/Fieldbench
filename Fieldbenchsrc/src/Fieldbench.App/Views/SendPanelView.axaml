<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Fieldbench.App.ViewModels"
             xmlns:conv="using:Fieldbench.App.Converters"
             xmlns:profiles="using:Fieldbench.Core.Profiles"
             xmlns:sys="using:System"
             x:Class="Fieldbench.App.Views.SendPanelView"
             x:DataType="vm:SendPanelViewModel">

    <StackPanel>
        <!-- compose row -->
        <DockPanel Margin="14,14,14,10" Height="30">
            <Border DockPanel.Dock="Left" Classes="seg" Height="30">
                <StackPanel Orientation="Horizontal">
                    <RadioButton Classes="seg-item" Content="HEX"
                                 FontFamily="{StaticResource FbMono}" FontSize="10"
                                 IsChecked="{Binding IsHexMode, Converter={x:Static conv:MiscConverters.TrueGate}}" />
                    <Rectangle Width="1" Fill="{DynamicResource FbCloud}" />
                    <RadioButton Classes="seg-item" Content="ASCII"
                                 FontFamily="{StaticResource FbMono}" FontSize="10"
                                 IsChecked="{Binding IsHexMode, Converter={x:Static conv:MiscConverters.FalseGate}}" />
                </StackPanel>
            </Border>

            <ComboBox DockPanel.Dock="Right" Margin="10,0,0,0" Width="150" MinHeight="30"
                      ItemsSource="{Binding ChecksumKinds}" SelectedItem="{Binding Checksum}"
                      FontSize="11.5">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding, Converter={x:Static conv:MiscConverters.ChecksumLabel}}" FontSize="11.5" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6" Margin="10,0,0,0">
                <CheckBox IsChecked="{Binding CycleEnabled}" Content="⟳" FontSize="12" MinHeight="30"
                          ToolTip.Tip="Cyclic send" />
                <NumericUpDown Value="{Binding CycleIntervalMs}" Minimum="10" Maximum="3600000" Increment="100"
                               FormatString="0" Width="110" MinHeight="30" Height="30" FontSize="11"
                               IsVisible="{Binding CycleEnabled}" />
            </StackPanel>

            <Button DockPanel.Dock="Right" Classes="primary" Height="30" Margin="10,0,0,0"
                    Command="{Binding SendCommand}">
                <Panel>
                    <TextBlock Text="{DynamicResource L.Send}" IsVisible="{Binding !IsCycling}" />
                    <TextBlock Text="■" IsVisible="{Binding IsCycling}" />
                </Panel>
            </Button>

            <TextBox Text="{Binding Payload}" Classes="mono" MinHeight="30" Height="30" FontSize="12"
                     Margin="10,0,0,0" Watermark="01 04 00 00 00 02" KeyDown="OnPayloadKeyDown" />
        </DockPanel>

        <TextBlock Text="{Binding Error}" FontSize="11" Foreground="{DynamicResource FbRed}" Margin="14,0,14,4"
                   IsVisible="{Binding Error, Converter={x:Static conv:FrameConverters.IsNotNull}}" />

        <!-- favorites -->
        <DockPanel Margin="14,4">
            <TextBlock Text="{DynamicResource L.Favorites}" Classes="micro" Width="74" VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <ItemsControl ItemsSource="{Binding Favorites}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="profiles:FavoriteFrame">
                            <Button Padding="12,4" CornerRadius="20" Background="{DynamicResource FbBg}"
                                    BorderBrush="{DynamicResource FbCloud}" BorderThickness="1" FontSize="11.5"
                                    Foreground="{DynamicResource FbGraphite}"
                                    Content="{Binding Name}"
                                    Command="{Binding $parent[ItemsControl].((vm:SendPanelViewModel)DataContext).LoadFavoriteCommand}"
                                    CommandParameter="{Binding}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button Padding="12,4" CornerRadius="20" Background="Transparent"
                        BorderBrush="{DynamicResource FbCloud}" BorderThickness="1" FontSize="11.5"
                        Foreground="{DynamicResource FbSilver}"
                        Content="{DynamicResource L.SaveCurrent}"
                        Command="{Binding SaveFavoriteCommand}" />
            </StackPanel>
        </DockPanel>

        <!-- recent -->
        <DockPanel Margin="14,4">
            <TextBlock Text="{DynamicResource L.Recent}" Classes="micro" Width="74" VerticalAlignment="Center" />
            <ItemsControl ItemsSource="{Binding History}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="14" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="sys:String">
                        <Button Padding="0" Background="Transparent" BorderThickness="0"
                                Command="{Binding $parent[ItemsControl].((vm:SendPanelViewModel)DataContext).LoadHistoryCommand}"
                                CommandParameter="{Binding}">
                            <TextBlock Text="{Binding}" Classes="mono" FontSize="11"
                                       Foreground="{DynamicResource FbPewter}" />
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </DockPanel>
    </StackPanel>
</UserControl>

<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
      Fieldbench design tokens — Tesla minimal, instrument density.
      Light is the default theme; dark derives from the same table
      (blue one notch brighter, three panel luminance levels).
      Field colors are the fixed product-wide four-color board:
      address purple / function blue / length teal / data grey (+ error red).
    -->

    <ResourceDictionary.ThemeDictionaries>

        <ResourceDictionary x:Key="Light">
            <Color x:Key="FbBlueColor">#3E6AE1</Color>
            <Color x:Key="FbBlueTintColor">#143E6AE1</Color>
            <Color x:Key="FbBlueTint2Color">#0E3E6AE1</Color>
            <Color x:Key="FbCarbonColor">#171A20</Color>
            <Color x:Key="FbGraphiteColor">#393C41</Color>
            <Color x:Key="FbPewterColor">#5C5E62</Color>
            <Color x:Key="FbSilverColor">#8E8E8E</Color>
            <Color x:Key="FbCloudColor">#EAEAEC</Color>
            <Color x:Key="FbAshColor">#F4F4F4</Color>
            <Color x:Key="FbBgColor">#FAFAFB</Color>
            <Color x:Key="FbPanelColor">#FFFFFF</Color>
            <Color x:Key="FbGreenColor">#1FA463</Color>
            <Color x:Key="FbAmberColor">#D9870A</Color>
            <Color x:Key="FbRedColor">#D9342B</Color>
            <Color x:Key="FbFieldAddrColor">#8A56D6</Color>
            <Color x:Key="FbFieldFuncColor">#0B3E97</Color>
            <Color x:Key="FbFieldLenColor">#00B386</Color>
            <Color x:Key="FbFieldDataColor">#5C5E62</Color>
            <Color x:Key="FbRxColor">#1989FA</Color>
            <Color x:Key="FbDotIdleColor">#D0D1D2</Color>
            <Color x:Key="FbRowLineColor">#0B171A20</Color>
            <Color x:Key="FbBlueOnColor">#3E6AE1</Color>
            <Color x:Key="FbScrimColor">#42171A20</Color>
            <Color x:Key="FbAmberTintColor">#14D9870A</Color>
            <Color x:Key="FbRedTintColor">#14D9342B</Color>
            <Color x:Key="FbAmberRowColor">#08D9870A</Color>
            <Color x:Key="FbRedRowColor">#08D9342B</Color>
            <Color x:Key="FbGreenTintColor">#141FA463</Color>
            <Color x:Key="FbAddrTintColor">#128A56D6</Color>
            <Color x:Key="FbFuncTintColor">#100B3E97</Color>
            <Color x:Key="FbLenTintColor">#1200B386</Color>
            <Color x:Key="FbGhostTextColor">#C4C6C9</Color>
        </ResourceDictionary>

        <ResourceDictionary x:Key="Dark">
            <Color x:Key="FbBlueColor">#537BE8</Color>
            <Color x:Key="FbBlueTintColor">#29537BE8</Color>
            <Color x:Key="FbBlueTint2Color">#1A537BE8</Color>
            <Color x:Key="FbCarbonColor">#EFF1F4</Color>
            <Color x:Key="FbGraphiteColor">#C6CAD1</Color>
            <Color x:Key="FbPewterColor">#9AA0A8</Color>
            <Color x:Key="FbSilverColor">#6A7078</Color>
            <Color x:Key="FbCloudColor">#12FFFFFF</Color>
            <Color x:Key="FbAshColor">#23262C</Color>
            <Color x:Key="FbBgColor">#141619</Color>
            <Color x:Key="FbPanelColor">#1B1E23</Color>
            <Color x:Key="FbGreenColor">#2CB474</Color>
            <Color x:Key="FbAmberColor">#E09A24</Color>
            <Color x:Key="FbRedColor">#E2503F</Color>
            <Color x:Key="FbFieldAddrColor">#A47BE8</Color>
            <Color x:Key="FbFieldFuncColor">#6E9FEF</Color>
            <Color x:Key="FbFieldLenColor">#1FC7A0</Color>
            <Color x:Key="FbFieldDataColor">#9AA3AD</Color>
            <Color x:Key="FbRxColor">#4E9BE8</Color>
            <Color x:Key="FbDotIdleColor">#3A3E45</Color>
            <Color x:Key="FbRowLineColor">#08FFFFFF</Color>
            <Color x:Key="FbBlueOnColor">#8FA9F2</Color>
            <Color x:Key="FbScrimColor">#66000000</Color>
            <Color x:Key="FbAmberTintColor">#24E09A24</Color>
            <Color x:Key="FbRedTintColor">#29E2503F</Color>
            <Color x:Key="FbAmberRowColor">#0DE09A24</Color>
            <Color x:Key="FbRedRowColor">#0FE2503F</Color>
            <Color x:Key="FbGreenTintColor">#242CB474</Color>
            <Color x:Key="FbAddrTintColor">#21A47BE8</Color>
            <Color x:Key="FbFuncTintColor">#216E9FEF</Color>
            <Color x:Key="FbLenTintColor">#211FC7A0</Color>
            <Color x:Key="FbGhostTextColor">#4A4F57</Color>
        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>

    <!-- Brushes over the theme colors -->
    <SolidColorBrush x:Key="FbBlue" Color="{DynamicResource FbBlueColor}" />
    <SolidColorBrush x:Key="FbBlueTint" Color="{DynamicResource FbBlueTintColor}" />
    <SolidColorBrush x:Key="FbBlueTint2" Color="{DynamicResource FbBlueTint2Color}" />
    <SolidColorBrush x:Key="FbBlueOn" Color="{DynamicResource FbBlueOnColor}" />
    <SolidColorBrush x:Key="FbCarbon" Color="{DynamicResource FbCarbonColor}" />
    <SolidColorBrush x:Key="FbGraphite" Color="{DynamicResource FbGraphiteColor}" />
    <SolidColorBrush x:Key="FbPewter" Color="{DynamicResource FbPewterColor}" />
    <SolidColorBrush x:Key="FbSilver" Color="{DynamicResource FbSilverColor}" />
    <SolidColorBrush x:Key="FbCloud" Color="{DynamicResource FbCloudColor}" />
    <SolidColorBrush x:Key="FbAsh" Color="{DynamicResource FbAshColor}" />
    <SolidColorBrush x:Key="FbBg" Color="{DynamicResource FbBgColor}" />
    <SolidColorBrush x:Key="FbPanel" Color="{DynamicResource FbPanelColor}" />
    <SolidColorBrush x:Key="FbGreen" Color="{DynamicResource FbGreenColor}" />
    <SolidColorBrush x:Key="FbAmber" Color="{DynamicResource FbAmberColor}" />
    <SolidColorBrush x:Key="FbRed" Color="{DynamicResource FbRedColor}" />
    <SolidColorBrush x:Key="FbFieldAddr" Color="{DynamicResource FbFieldAddrColor}" />
    <SolidColorBrush x:Key="FbFieldFunc" Color="{DynamicResource FbFieldFuncColor}" />
    <SolidColorBrush x:Key="FbFieldLen" Color="{DynamicResource FbFieldLenColor}" />
    <SolidColorBrush x:Key="FbFieldData" Color="{DynamicResource FbFieldDataColor}" />
    <SolidColorBrush x:Key="FbRx" Color="{DynamicResource FbRxColor}" />
    <SolidColorBrush x:Key="FbDotIdle" Color="{DynamicResource FbDotIdleColor}" />
    <SolidColorBrush x:Key="FbRowLine" Color="{DynamicResource FbRowLineColor}" />
    <SolidColorBrush x:Key="FbScrim" Color="{DynamicResource FbScrimColor}" />
    <SolidColorBrush x:Key="FbAmberTint" Color="{DynamicResource FbAmberTintColor}" />
    <SolidColorBrush x:Key="FbRedTint" Color="{DynamicResource FbRedTintColor}" />
    <SolidColorBrush x:Key="FbAmberRow" Color="{DynamicResource FbAmberRowColor}" />
    <SolidColorBrush x:Key="FbRedRow" Color="{DynamicResource FbRedRowColor}" />
    <SolidColorBrush x:Key="FbGreenTint" Color="{DynamicResource FbGreenTintColor}" />
    <SolidColorBrush x:Key="FbAddrTint" Color="{DynamicResource FbAddrTintColor}" />
    <SolidColorBrush x:Key="FbFuncTint" Color="{DynamicResource FbFuncTintColor}" />
    <SolidColorBrush x:Key="FbLenTint" Color="{DynamicResource FbLenTintColor}" />
    <SolidColorBrush x:Key="FbGhostText" Color="{DynamicResource FbGhostTextColor}" />


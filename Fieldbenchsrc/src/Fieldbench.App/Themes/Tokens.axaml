    <FontFamily x:Key="FbMono">Cascadia Code, SF Mono, Consolas, DejaVu Sans Mono, Noto Sans Mono, monospace</FontFamily>
    <FontFamily x:Key="FbSans">Inter, Segoe UI, PingFang SC, Noto Sans CJK SC, Helvetica Neue, Arial, sans-serif</FontFamily>

    <CornerRadius x:Key="FbRadius">4</CornerRadius>
    <x:Double x:Key="FbRowHeight">26</x:Double>

</ResourceDictionary>
